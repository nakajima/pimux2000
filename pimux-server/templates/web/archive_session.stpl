<% include!("_layout_start.stpl"); %>
<% include!("_page_header.stpl"); %>

<section class="card session-card">
  <dl class="key-value-list">
    <div>
      <dt>Host auth</dt>
      <dd><%= host_auth %></dd>
    </div>
    <div>
      <dt>Created</dt>
      <dd><%= created_at %></dd>
    </div>
    <div>
      <dt>Updated</dt>
      <dd><%= updated_at %></dd>
    </div>
    <div>
      <dt>Last user message</dt>
      <dd><%= last_user_message_at %></dd>
    </div>
    <div>
      <dt>Last assistant message</dt>
      <dd><%= last_assistant_message_at %></dd>
    </div>
    <div>
      <dt>Last seen by archive</dt>
      <dd><%= last_seen_at %></dd>
    </div>
    <div>
      <dt>Model</dt>
      <dd><%= model %></dd>
    </div>
    <div>
      <dt>Working directory</dt>
      <dd><%= cwd %></dd>
    </div>
    <div>
      <dt>Transcript freshness</dt>
      <dd><%= transcript_freshness %></dd>
    </div>
    <div>
      <dt>Activity</dt>
      <dd><%= activity %></dd>
    </div>
    <div>
      <dt>Archived messages</dt>
      <dd><%= message_count %></dd>
    </div>
  </dl>

  <% if let Some(selected_message_key) = &selected_message_key { %>
    <div class="callout">
      <% if !selected_message_found { %>
        Message <code><%= selected_message_key %></code> was not found in the archived transcript. Showing the full session instead.
      <% } %>
    </div>
  <% } %>
</section>

<section class="card session-card" style="margin-top: 18px;">
  <% if messages.is_empty() { %>
    <p class="empty">No archived messages were found for this session.</p>
  <% } else { %>
    <ol class="message-list">
      <% for message in &messages { %>
        <li id="<%= message.anchor_id %>" class="message-item<% if message.is_selected { %> selected<% } %> <%= message.role_class %>">
          <div class="message-header">
             <span class="role-pill "><%= message.role %></span>
            <% if let Some(tool_name) = &message.tool_name { %>
                <span class="meta">tool: <code><%= tool_name %></code></span>
            <% } %>
            <% if let Some(tool_call_badge) = &message.tool_call_badge { %>
              <span class="meta">call: <code><%= tool_call_badge %></code></span>
            <% } %>

            <div class="message-meta">
              <a class="permalink" href="<%= message.permalink_url %>" title="Permalink to this message"><%= message.created_at %></a>
              <span class="meta"><code><%= message.message_key %></code></span>
            </div>

          </div>
          <% if let Some(related_tool_call) = &message.related_tool_call { %>
            <div class="message-link-callout">
              <a href="<%= related_tool_call.url %>"><%= related_tool_call.label %></a>
            </div>
          <% } %>
          <% if !message.tool_call_blocks.is_empty() { %>
            <ul class="tool-call-list">
              <% for tool_call in &message.tool_call_blocks { %>
                <li id="<%= tool_call.anchor_id %>" class="tool-call-item">
                  <div class="tool-call-header">
                    <strong><%= tool_call.tool_name %></strong>
                    <% if let Some(tool_call_badge) = &tool_call.tool_call_badge { %>
                      <span class="meta"><code><%= tool_call_badge %></code></span>
                    <% } %>
                    <% if let Some(result_link) = &tool_call.result_link { %>
                      <a href="<%= result_link.url %>"><%= result_link.label %></a>
                    <% } %>
                  </div>
                  <div class="tool-call-body"><%- tool_call.body_html %></div>
                </li>
              <% } %>
            </ul>
          <% } %>
          <div class="message-body <%= message.body_format_class %>"><%- message.body_html %></div>
        </li>
      <% } %>
    </ol>
  <% } %>
</section>

<% include!("_layout_end.stpl"); %>
